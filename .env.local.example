# Copy this file to .env.local and fill in values from Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Public site URL (magic link redirects, admin notifications)
NEXT_PUBLIC_SITE_URL=https://thewellnesskorea.com

# Settings → API → service_role (secret) — only for scripts/server, never commit or expose in browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Teacher self-registration
TEACHER_APPLY_CODE=twk2026

# Admin notifications on profile submit (email → all Supabase admin users)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
RESEND_API_KEY=re_xxx
NOTIFY_FROM_EMAIL=notify@thewellnesskorea.com

# Optional: defaults for npm run create-admin (without CLI args)
# ADMIN_EMAIL=admin@thewellnesskorea.com
# ADMIN_PASSWORD=change-me-123

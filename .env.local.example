# Copy this file to .env.local and fill in values from Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Settings → API → service_role (secret) — only for scripts, never commit or expose in browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: defaults for npm run create-admin (without CLI args)
# ADMIN_EMAIL=admin@thewellnesskorea.com
# ADMIN_PASSWORD=change-me-123
